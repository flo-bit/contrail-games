{
  "lexicon": 1,
  "id": "games.atmo.fours.puzzleList",
  "defs": {
    "main": {
      "type": "record",
      "description": "A list of puzzle URIs curated by a user. Used to power daily puzzle feeds.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["puzzles"],
        "properties": {
          "puzzles": {
            "type": "array",
            "description": "Ordered list of AT URIs pointing to games.atmo.fours.puzzle records.",
            "items": {
              "type": "string",
              "format": "at-uri"
            }
          }
        }
      }
    }
  }
}
