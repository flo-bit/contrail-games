{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "contrail",
  "main": "src/adapters/worker.ts",
  "compatibility_date": "2025-12-25",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "contrail",
      "database_id": "FILL_IN_DATABASE_ID"
    }
  ],
  "triggers": {
    "crons": ["*/1 * * * *"]
  }
}
