{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "contrail-games",
	"main": "src/adapters/worker.ts",
	"compatibility_date": "2025-12-25",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "contrail",
			"database_id": "28c93587-64f8-4819-9119-6a0f84b3d537",
			"remote": true
		}
	],
	"triggers": {
		"crons": [
			"*/1 * * * *"
		]
	}
}