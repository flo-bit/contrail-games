{
  "lexicon": 1,
  "id": "contrail.admin.sync",
  "defs": {
    "main": {
      "type": "query",
      "description": "Discover users from relays and backfill their records from PDS",
      "parameters": {
        "type": "params",
        "properties": {
          "concurrency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "discovered",
            "backfilled",
            "remaining",
            "done"
          ],
          "properties": {
            "discovered": {
              "type": "integer"
            },
            "backfilled": {
              "type": "integer"
            },
            "remaining": {
              "type": "integer"
            },
            "done": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
