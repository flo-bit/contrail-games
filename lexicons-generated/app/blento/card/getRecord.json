{
  "lexicon": 1,
  "id": "app.blento.card.getRecord",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a single app.blento.card record by AT URI",
      "parameters": {
        "type": "params",
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the record"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#record"
        }
      }
    },
    "record": {
      "type": "object",
      "required": [
        "uri",
        "did",
        "collection",
        "rkey",
        "time_us"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "did": {
          "type": "string",
          "format": "did"
        },
        "collection": {
          "type": "string",
          "format": "nsid"
        },
        "rkey": {
          "type": "string"
        },
        "cid": {
          "type": "string"
        },
        "record": {
          "type": "unknown"
        },
        "time_us": {
          "type": "integer"
        }
      }
    }
  }
}
