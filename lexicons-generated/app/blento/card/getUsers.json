{
  "lexicon": 1,
  "id": "app.blento.card.getUsers",
  "defs": {
    "main": {
      "type": "query",
      "description": "List users who have app.blento.card records",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "users"
          ],
          "properties": {
            "users": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#userRecord"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    },
    "userRecord": {
      "type": "object",
      "required": [
        "did",
        "record_count"
      ],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "record_count": {
          "type": "integer"
        }
      }
    }
  }
}
